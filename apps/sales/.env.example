# ──────────────────────────────────────────────────────────────────────────────
# sales.onvero.de — Environment Variables
# Copy to .env.local for local dev. In Vercel: Project Settings → Environment
# Variables (NEVER commit real values — only NEXT_PUBLIC_* reach the browser).
# This list is the complete set referenced by the code (apps/sales + packages/lib).
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* are exposed to the browser — only the public anon key, never secrets.
NEXT_PUBLIC_SUPABASE_URL=https://jnaqmsvozkpqawqwslrl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — keep secret, never prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth (Cross-Subdomain SSO) ───────────────────────────────────────────────
# Set to .onvero.de in production so the auth cookie is shared across subdomains.
# Leave UNSET locally so localhost dev cookies stay host-only.
# AUTH_COOKIE_DOMAIN=.onvero.de

# ── Rate Limiting (Upstash Redis — used by @onvero/lib/rate-limit) ───────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── External APIs ────────────────────────────────────────────────────────────
GROQ_API_KEY=          # Whisper transcription
PLAUSIBLE_API_KEY=     # Analytics stats

# ── Webhook signing / shared secrets (server-side) ───────────────────────────
N8N_WEBHOOK_SECRET=          # HMAC signing of outbound n8n payloads
N8N_LEAD_GENERATOR_SECRET=   # Shared secret for the lead-generator callback
RESEND_WEBHOOK_SECRET=       # Verifies inbound Resend bounce webhooks

# Public base URL sent to n8n as callback_url. Required in dev (localhost:3001) —
# set to a tunnel URL like https://abc123.ngrok-free.app. Leave empty in prod
# (route falls back to the request origin).
PUBLIC_BASE_URL=

# ──────────────────────────────────────────────────────────────────────────────
# n8n Webhooks — SERVER-SIDE ONLY. Never prefix NEXT_PUBLIC_. The client never
# sees these URLs; it POSTs an action name to /api/proxy/n8n and the server
# resolves the URL from these vars.
# ──────────────────────────────────────────────────────────────────────────────

# Lead generation & scoring
N8N_WEBHOOK_LEAD_GENERATOR=
N8N_WEBHOOK_LEAD_REASONING=
N8N_WEBHOOK_LEAD_STATS=
N8N_WEBHOOK_KI_SCORING=
N8N_WEBHOOK_MAPS_IMPORT=

# Apollo / people enrichment
N8N_WEBHOOK_APOLLO_ORG_AGENT=
N8N_WEBHOOK_APOLLO_PEOPLE_AGENT=
N8N_WEBHOOK_APOLLO_PEOPLE=
N8N_WEBHOOK_PERSON_ENRICH=

# Discovery / deep research
N8N_WEBHOOK_DISCOVERY_AGENT=
N8N_WEBHOOK_DEEP_RESEARCH_PARALLEL=

# Email
N8N_WEBHOOK_SEND_EMAIL=
N8N_WEBHOOK_SEND_OUTREACH_EMAIL=
N8N_WEBHOOK_EMAIL_AI_REWRITE=
N8N_WEBHOOK_EMAIL_REWRITE=
N8N_WEBHOOK_EMAIL_STYLE_AGENT=

# Chat
N8N_WEBHOOK_CHAT=
N8N_WEBHOOK_CHAT_IMAGE=
N8N_WEBHOOK_LEAD_RESEARCH_CHAT=

# Meetings
N8N_WEBHOOK_MEETING_SUMMARIZER=
N8N_WEBHOOK_MEETING_ANALYZER=
N8N_WEBHOOK_MEETING_BRIEFING=
N8N_WEBHOOK_MEETING_EMAIL_CHECK=
N8N_WEBHOOK_MEETING_CALENDAR=
N8N_WEBHOOK_MEETING_AUTO_SUGGEST=

# Content / research
N8N_WEBHOOK_WEBSITE_ANALYSIS=
N8N_WEBHOOK_BLOG_AI_POLISH=
N8N_WEBHOOK_VECTOR_STORE=
